# cognitive-core — шаблон переменных окружения.
# Скопируйте в .env и подставьте реальные значения. .env исключён в .gitignore
# (см. секцию "Local environment / secrets"), в коммит не попадёт.
#
# CLI автоматически загружает .env из текущей директории при запуске
# `cognitive-core ...`. Реальные переменные окружения имеют приоритет над .env.

# Blackbox AI (pip install cognitive-core[openai]; OpenAI-совместимый API)
BLACKBOX_API_KEY=

# OpenAI (pip install cognitive-core[openai])
# OPENAI_API_KEY=

# Anthropic / Claude (pip install cognitive-core[anthropic])
# ANTHROPIC_API_KEY=
